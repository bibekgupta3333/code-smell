{
  "ablation_studies_config": {
    "description": "Systematic Ablation Studies for RAG and Prompt Engineering",
    "experiment_type": "ablation",
    "phase": "Phase 4.2 (Weeks 9)",
    "studies": {
      "rag_hyperparameters": {
        "description": "Vary RAG parameters to find optimal configuration",
        "parameters": {
          "top_k": {
            "values": [1, 3, 5, 10],
            "default": 5,
            "reason": "Benchmarking Section 5 cross-validation"
          },
          "similarity_threshold": {
            "values": [0.5, 0.6, 0.7, 0.8],
            "default": 0.7,
            "reason": "Filter retrieved examples by relevance"
          },
          "diversity_lambda": {
            "values": [0.5, 0.7, 0.9],
            "default": 0.7,
            "reason": "MMR diversity parameter for example diversity"
          }
        },
        "method": "grid_search",
        "evaluation": "5_fold_cross_validation",
        "metric": "f1_score"
      },
      "embedding_models": {
        "description": "Compare different embedding models for RAG",
        "embedding_models": [
          "sentence-transformers/all-MiniLM-L6-v2",
          "sentence-transformers/bge-small-en-v1.5",
          "sentence-transformers/paraphrase-MiniLM-L6-v2"
        ],
        "default": "sentence-transformers/all-MiniLM-L6-v2",
        "reason": "Lightweight, 384-dim, fast inference on M4 Pro"
      },
      "prompt_variants": {
        "description": "Test different prompting strategies",
        "variants": [
          "default",
          "detailed",
          "structured_json",
          "with_examples",
          "chain_of_thought"
        ],
        "metric": "f1_score",
        "expected_impact": "5-10% variance"
      },
      "model_size_comparison": {
        "description": "Compare model sizes for accuracy-latency tradeoff",
        "models": [
          "llama3:7b",
          "llama3:8b",
          "llama3:13b",
          "codellama:7b",
          "codellama:13b"
        ],
        "metrics": ["f1_score", "latency_ms", "memory_mb", "tokens_per_analysis"]
      }
    },
    "validation_method": {
      "strategy": "5_fold_cross_validation",
      "test_set": "Hold out 20% from Benchmarking Section 1",
      "repeated_runs": 3,
      "random_seeds": [42, 123, 456],
      "reason": "Ensure reproducibility and stability across runs"
    },
    "output": {
      "per_smell_type_breakdown": true,
      "heatmaps": true,
      "sensitivity_analysis": true,
      "optimal_configuration": true
    },
    "performance_targets": {
      "f1_improvement_target": "10-15%",
      "compute_budget": "2 hours CPU",
      "latency_overhead": "< 10%"
    },
    "notes": "Systematic ablation study to understand which factors drive improvement. Results guide final model configuration."
  },
  "cross_language_validation": {
    "description": "Phase 4.3: Validate across Java, Python, JavaScript (Week 10)",
    "languages": ["java", "python", "javascript"],
    "per_language_metrics": true,
    "evaluation": "Generalization across programming languages",
    "expected_finding": "Per-language performance variance analysis"
  }
}
