{
  "name": "code-smell-llm",
  "version": "0.1.0",
  "private": true,
  "description": "LLM-based code smell detection — 5 prompt strategies × 4 languages × {annotated, unannotated} × {local, cloud}.",
  "scripts": {
    "p1": "python -m srccode.run_p1_zero_shot",
    "p2": "python -m srccode.run_p2_few_shot",
    "p3": "python -m srccode.run_p3_taxonomy_tree",
    "p4": "python -m srccode.run_p4_self_verify",
    "p5": "python -m srccode.run_p5_rag",

    "rag:build":         "python -m srccode.build_rag_index",
    "p5:random:py":      "python -m srccode.run_p5_rag --provider local --dataset annotated --split python     --rag-mode random --verbose",
    "p5:random:java":    "python -m srccode.run_p5_rag --provider local --dataset annotated --split java       --rag-mode random --verbose",
    "p5:random:js":      "python -m srccode.run_p5_rag --provider local --dataset annotated --split javascript --rag-mode random --verbose",
    "p5:random:cpp":     "python -m srccode.run_p5_rag --provider local --dataset annotated --split cpp        --rag-mode random --verbose",
    "p5:k3:py":          "python -m srccode.run_p5_rag --provider local --dataset annotated --split python     --rag-k 3 --verbose",
    "p5:k3:java":        "python -m srccode.run_p5_rag --provider local --dataset annotated --split java       --rag-k 3 --verbose",
    "p5:k3:js":          "python -m srccode.run_p5_rag --provider local --dataset annotated --split javascript --rag-k 3 --verbose",
    "p5:k3:cpp":         "python -m srccode.run_p5_rag --provider local --dataset annotated --split cpp        --rag-k 3 --verbose",

    "p1:local:py":   "python -m srccode.run_p1_zero_shot     --provider local --dataset annotated --split python     --verbose",
    "p2:local:py":   "python -m srccode.run_p2_few_shot      --provider local --dataset annotated --split python     --verbose",
    "p3:local:py":   "python -m srccode.run_p3_taxonomy_tree --provider local --dataset annotated --split python     --verbose",
    "p4:local:py":   "python -m srccode.run_p4_self_verify   --provider local --dataset annotated --split python     --verbose",
    "p5:local:py":   "python -m srccode.run_p5_rag           --provider local --dataset annotated --split python     --verbose",

    "p1:local:java": "python -m srccode.run_p1_zero_shot     --provider local --dataset annotated --split java       --verbose",
    "p2:local:java": "python -m srccode.run_p2_few_shot      --provider local --dataset annotated --split java       --verbose",
    "p3:local:java": "python -m srccode.run_p3_taxonomy_tree --provider local --dataset annotated --split java       --verbose",
    "p4:local:java": "python -m srccode.run_p4_self_verify   --provider local --dataset annotated --split java       --verbose",
    "p5:local:java": "python -m srccode.run_p5_rag           --provider local --dataset annotated --split java       --verbose",

    "p1:local:js":   "python -m srccode.run_p1_zero_shot     --provider local --dataset annotated --split javascript --verbose",
    "p2:local:js":   "python -m srccode.run_p2_few_shot      --provider local --dataset annotated --split javascript --verbose",
    "p3:local:js":   "python -m srccode.run_p3_taxonomy_tree --provider local --dataset annotated --split javascript --verbose",
    "p4:local:js":   "python -m srccode.run_p4_self_verify   --provider local --dataset annotated --split javascript --verbose",
    "p5:local:js":   "python -m srccode.run_p5_rag           --provider local --dataset annotated --split javascript --verbose",

    "p1:local:cpp":  "python -m srccode.run_p1_zero_shot     --provider local --dataset annotated --split cpp        --verbose",
    "p2:local:cpp":  "python -m srccode.run_p2_few_shot      --provider local --dataset annotated --split cpp        --verbose",
    "p3:local:cpp":  "python -m srccode.run_p3_taxonomy_tree --provider local --dataset annotated --split cpp        --verbose",
    "p4:local:cpp":  "python -m srccode.run_p4_self_verify   --provider local --dataset annotated --split cpp        --verbose",
    "p5:local:cpp":  "python -m srccode.run_p5_rag           --provider local --dataset annotated --split cpp        --verbose",

    "p1:cloud:py":   "python -m srccode.run_p1_zero_shot     --provider cloud --dataset annotated --split python     --verbose",
    "p2:cloud:py":   "python -m srccode.run_p2_few_shot      --provider cloud --dataset annotated --split python     --verbose",
    "p3:cloud:py":   "python -m srccode.run_p3_taxonomy_tree --provider cloud --dataset annotated --split python     --verbose",
    "p4:cloud:py":   "python -m srccode.run_p4_self_verify   --provider cloud --dataset annotated --split python     --verbose",
    "p5:cloud:py":   "python -m srccode.run_p5_rag           --provider cloud --dataset annotated --split python     --verbose",

    "p1:cloud:java": "python -m srccode.run_p1_zero_shot     --provider cloud --dataset annotated --split java       --verbose",
    "p2:cloud:java": "python -m srccode.run_p2_few_shot      --provider cloud --dataset annotated --split java       --verbose",
    "p3:cloud:java": "python -m srccode.run_p3_taxonomy_tree --provider cloud --dataset annotated --split java       --verbose",
    "p4:cloud:java": "python -m srccode.run_p4_self_verify   --provider cloud --dataset annotated --split java       --verbose",
    "p5:cloud:java": "python -m srccode.run_p5_rag           --provider cloud --dataset annotated --split java       --verbose",

    "p1:cloud:js":   "python -m srccode.run_p1_zero_shot     --provider cloud --dataset annotated --split javascript --verbose",
    "p2:cloud:js":   "python -m srccode.run_p2_few_shot      --provider cloud --dataset annotated --split javascript --verbose",
    "p3:cloud:js":   "python -m srccode.run_p3_taxonomy_tree --provider cloud --dataset annotated --split javascript --verbose",
    "p4:cloud:js":   "python -m srccode.run_p4_self_verify   --provider cloud --dataset annotated --split javascript --verbose",
    "p5:cloud:js":   "python -m srccode.run_p5_rag           --provider cloud --dataset annotated --split javascript --verbose",

    "p1:cloud:cpp":  "python -m srccode.run_p1_zero_shot     --provider cloud --dataset annotated --split cpp        --verbose",
    "p2:cloud:cpp":  "python -m srccode.run_p2_few_shot      --provider cloud --dataset annotated --split cpp        --verbose",
    "p3:cloud:cpp":  "python -m srccode.run_p3_taxonomy_tree --provider cloud --dataset annotated --split cpp        --verbose",
    "p4:cloud:cpp":  "python -m srccode.run_p4_self_verify   --provider cloud --dataset annotated --split cpp        --verbose",
    "p5:cloud:cpp":  "python -m srccode.run_p5_rag           --provider cloud --dataset annotated --split cpp        --verbose",

    "all:local:py":   "npm run p1:local:py   && npm run p2:local:py   && npm run p3:local:py   && npm run p4:local:py   && npm run p5:local:py",
    "all:local:java": "npm run p1:local:java && npm run p2:local:java && npm run p3:local:java && npm run p4:local:java && npm run p5:local:java",
    "all:local:js":   "npm run p1:local:js   && npm run p2:local:js   && npm run p3:local:js   && npm run p4:local:js   && npm run p5:local:js",
    "all:local:cpp":  "npm run p1:local:cpp  && npm run p2:local:cpp  && npm run p3:local:cpp  && npm run p4:local:cpp  && npm run p5:local:cpp",
    "all:local":      "npm run all:local:py && npm run all:local:java && npm run all:local:js && npm run all:local:cpp",

    "all:cloud:py":   "npm run p1:cloud:py   && npm run p2:cloud:py   && npm run p3:cloud:py   && npm run p4:cloud:py   && npm run p5:cloud:py",
    "all:cloud:java": "npm run p1:cloud:java && npm run p2:cloud:java && npm run p3:cloud:java && npm run p4:cloud:java && npm run p5:cloud:java",
    "all:cloud:js":   "npm run p1:cloud:js   && npm run p2:cloud:js   && npm run p3:cloud:js   && npm run p4:cloud:js   && npm run p5:cloud:js",
    "all:cloud:cpp":  "npm run p1:cloud:cpp  && npm run p2:cloud:cpp  && npm run p3:cloud:cpp  && npm run p4:cloud:cpp  && npm run p5:cloud:cpp",
    "all:cloud":      "npm run all:cloud:py && npm run all:cloud:java && npm run all:cloud:js && npm run all:cloud:cpp"
  }
}
