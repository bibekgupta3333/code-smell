{
  "name": "code-smell-detection-api",
  "version": "1.0.0",
  "description": "Privacy-preserving LLM-based code smell detection with RAG enhancement",
  "main": "src/api_server.py",
  "scripts": {
    "help": "make help",
    "clean": "make clean",
    "venv": "make venv",
    "install": "make install",
    "run-detector": "make run-detector",
    "run-workflow": "make run-workflow",
    "run-coordinator": "make run-coordinator",
    "run-database": "make run-database",
    "run-all": "make run-all",
    "baseline-install": "make baseline-install",
    "baseline-install-verify": "make baseline-install-verify",
    "baseline-java": "make baseline-java",
    "baseline-python": "make baseline-python",
    "baseline-js": "make baseline-js",
    "baseline-run": "make baseline-run",
    "baseline-report": "make baseline-report",
    "baseline-verify": "make baseline-verify",
    "llm-baseline-run": "make llm-baseline-run",
    "llm-rag-run": "make llm-rag-run",
    "llm-ablation-run": "make llm-ablation-run",
    "inference-quick": "make inference-quick",
    "inference-baseline": "make inference-baseline",
    "inference-rag": "make inference-rag",
    "inference-results": "make inference-results",
    "api-dev": "make api-dev",
    "api-start": "make api-start",
    "api-prod": "make api-prod",
    "api-test": "make api-test",
    "api-docs": "make api-docs",
    "dev": "npm run api-dev",
    "start": "npm run api-start",
    "prod": "npm run api-prod",
    "test": "npm run api-test",
    "docs": "npm run api-docs",
    "frontend-dev": "source .venv/bin/activate && python3 -m uvicorn src.api_server:app --reload --host 0.0.0.0 --port 8000",
    "lint": "pylint src/",
    "format": "black src/ scripts/",
    "pytest": "pytest tests/ -v",
    "pytest:watch": "pytest tests/ -v --watch",
    "analyze": "python scripts/analysis/analyze_results.py"
  },
  "keywords": [
    "code-smell",
    "llm",
    "code-analysis",
    "fastapi",
    "rag",
    "ollama",
    "privacy-preserving"
  ],
  "author": "Code Smell Detection Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bibekgupta3333/code-smell.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "python": ">=3.11.0"
  },
  "devDependencies": {},
  "dependencies": {}
}
